# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ── Virtual environments ──
venv/
.venv/
env/

# ── Model weights (large; regenerated by training or downloaded on first run) ──
