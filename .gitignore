# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ── Virtual environments ──
venv/
.venv/
env/

# ── Model weights (large) ──
# Ignore weights by default (best_model_classic10.pth, mobile_sam.pt, teacher/
# student_*.pth ...) but DO ship the final 17-class model so the demo/eval run
# out of the box. (best_model.pth is ~90 MB — under GitHub's 100 MB hard limit.)
*.pth
*.pt
!checkpoints/best_model.pth

# ── Datasets (large; rebuild with the data/ scripts, see README) ──
dataset/
dataset_hf/
dataset_youtube_hq/
dataset_combined/
dataset_rejected/
raw_videos/

# ── Data manifests / generated tables ──
*.csv

# ── Gradio runtime & demo example cache ──
.gradio/
examples/

# ── Data-cleaning scratch space ──
tobeclean/

# ── Logs ──
*.log

# ── OS / editor / tooling junk ──
.DS_Store
.Rhistory
.claude/
.vscode/
.idea/
*.swp
