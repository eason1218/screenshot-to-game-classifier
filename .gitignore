*.pth
*.pt

# ── Datasets (large; rebuild with the data/ scripts, see README) ──
dataset/
dataset_hf/
dataset_youtube_hq/
dataset_combined/
dataset_rejected/
raw_videos/

# ── Data manifests / generated tables ──
*.csv

# ── Gradio runtime & demo example cache ──
.gradio/
examples/

# ── Data-cleaning scratch space ──
tobeclean/

# ── Logs ──
*.log

# ── OS / editor / tooling junk ──
.DS_Store
.Rhistory
.claude/
.vscode/
.idea/
*.swp
